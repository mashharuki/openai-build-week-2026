{
  "name": "openai-build-week-2026",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "format" : "biome format --write .",
    "build": "pnpm --filter './pkgs/**' --if-present run build",
    "lint": "biome check pkgs tests",
    "test": "pnpm run test:workspace && pnpm run test:e2e && pnpm --filter './pkgs/**' --if-present run test",
    "test:e2e": "vitest run tests/e2e",
    "test:workspace": "node --test tests/workspace.test.mjs",
    "typecheck": "pnpm --filter './pkgs/**' --if-present run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
